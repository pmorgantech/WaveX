# ESP32 WaveX Configuration Defaults

# Compiler optimization
CONFIG_COMPILER_OPTIMIZATION_PERF=y
CONFIG_COMPILER_OPTIMIZATION_ASSERTIONS_DISABLE=y

# FreeRTOS configuration
CONFIG_FREERTOS_HZ=1000
CONFIG_FREERTOS_UNICORE=n

# SPI configuration  
CONFIG_SPI_MASTER_IN_IRAM=y
CONFIG_SPI_MASTER_ISR_IN_IRAM=y

# Memory configuration
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192
CONFIG_ESP_INT_WDT_TIMEOUT_MS=800

# WiFi/Bluetooth - completely disable to save power and memory
CONFIG_BT_ENABLED=n
CONFIG_BT_NIMBLE_ENABLED=n
CONFIG_BT_CLASSIC_ENABLED=n
CONFIG_BT_CONTROLLER_ENABLED=n
CONFIG_WIFI_ENABLED=n
CONFIG_ESP_WIFI_ENABLED=n
CONFIG_ESP_WIFI_SOFTAP_SUPPORT=n
CONFIG_ESP_WIFI_STA_SUPPORT=n
CONFIG_ESP_WIFI_ENTERPRISE_SUPPORT=n

# Disable networking components
CONFIG_LWIP_IPV4=n
CONFIG_LWIP_IPV6=n
CONFIG_LWIP_ETHERNET=n

# Disable HTTP/HTTPS components  
CONFIG_ESP_HTTP_CLIENT_ENABLE_HTTPS=n
CONFIG_ESP_HTTPS_OTA_ALLOW_HTTP=n

# Power management optimizations
CONFIG_PM_ENABLE=y
CONFIG_PM_DFS_INIT_AUTO=y
CONFIG_PM_POWER_DOWN_CPU_IN_LIGHT_SLEEP=y
CONFIG_PM_POWER_DOWN_TAGMEM_IN_LIGHT_SLEEP=y

# Console configuration
CONFIG_ESP_CONSOLE_UART_DEFAULT=y
CONFIG_ESP_CONSOLE_UART_BAUDRATE_115200=y

# Log level
CONFIG_LOG_DEFAULT_LEVEL_INFO=y

# PSRAM configuration (if available)
CONFIG_SPIRAM_SUPPORT=y
CONFIG_SPIRAM_USE_MALLOC=y
CONFIG_SPIRAM_TYPE_AUTO=y

# Audio-focused optimizations
CONFIG_ESP32_DEFAULT_CPU_FREQ_240=y
CONFIG_ESP32S3_DEFAULT_CPU_FREQ_240=y
CONFIG_ESP_TASK_WDT=n

# Reduce unused features for audio device
CONFIG_ESP_GDBSTUB_ENABLED=n
CONFIG_ESP_DEBUG_OCDAWARE=n
CONFIG_ESP_SYSTEM_EVENT_TASK_STACK_SIZE=2048

# Memory optimizations
CONFIG_ESP_ERR_TO_NAME_LOOKUP=n
CONFIG_ESP_TIMER_PROFILING=n
CONFIG_HEAP_TRACING=n 