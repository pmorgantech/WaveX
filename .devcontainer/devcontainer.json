{
  "name": "WaveX Dual-MCU Synth DevContainer",
  "build": { "dockerfile": "Dockerfile" },
  "image": "wavex-devcontainer:latest",
  "runArgs": [
    "--privileged",
    "--device=/dev/bus/usb",
    "--volume=/dev:/dev",
    "--group-add=plugdev",
    "--group-add=dialout",
    "--device=/dev/ttyUSB0",
    "--device=/dev/ttyUSB1",
    "--device=/dev/ttyACM0",
    "--device=/dev/ttyACM1"
  ],
  "remoteUser": "petem",
  "updateRemoteUserUID": true,
  "extensions": [
    "ms-vscode.cpptools",
    "ms-vscode.cpptools-extension-pack",
    "ms-vscode.cmake-tools",
    "espressif.esp-idf-extension-pack",
    "marus25.cortex-debug",
    "bierner.markdown-mermaid",
    "ms-vscode.makefile-tools"
  ],
  "postCreateCommand": "bash -c 'grep -q \"export.sh\" ~/.bashrc || echo \"source /opt/esp/idf/export.sh\" >> ~/.bashrc'"
}
